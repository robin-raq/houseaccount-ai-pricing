# Copy to .env (gitignored) and fill in. Never commit real secret values.

# OpenAI key — powers runtime LLM scope extraction and the demo-video narration.
# Server-side only; never sent to the browser. Rotate after the eval is done.
OPENAI_API_KEY=

# Bearer secret HouseAccount uses to call the /pricing-estimate endpoint.
# Generate one: `openssl rand -hex 32`.
GAUNTLET_PRICING_SECRET=

# Internal URL the Rails API uses to reach the Python model service.
MODEL_SERVICE_URL=http://localhost:8000

# Optional outbound integration: HouseAccount staging booking-create endpoint.
# Leave blank to run the documented stub (estimates are logged as "skipped").
STAGING_BOOKINGS_URL=
STAGING_BOOKINGS_TOKEN=
