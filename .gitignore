# Secrets — never commit
.env
.env.*
!.env.example

# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# Trained model artifacts (regenerated by `make train`; too large / not source)
artifacts/
*.joblib
*.pkl

# Rails
/api/log/*
/api/tmp/*
/api/storage/*
/api/.bundle
/api/vendor/bundle
!/api/log/.keep
!/api/tmp/.keep

# Reference screenshots (Phase 2 captures — kept local, not shipped to repo)
design/*.png

# Node / Playwright
node_modules/
test-results/
playwright-report/
.playwright/

# Demo video intermediates (large binaries; final mp4 shared separately)
demo/clips/
demo/audio/
demo/*.mp4

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
