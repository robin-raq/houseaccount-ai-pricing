# Secrets — never commit
.env
.env.*
!.env.example

# Python
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
*.egg-info/

# Scratch model artifacts (bake-off output, LLM scope cache) — regenerated
artifacts/
*.joblib
*.pkl
# ...but DO ship the trained model + its metadata (deployed from the repo)
!model_service/model/model.joblib
!model_service/model/model_meta.json

# Raw client dataset stays out of the public repo (sanitized, but still their data)
data/raw/*.csv

# Rails
/api/log/*
/api/tmp/*
/api/storage/*
/api/.bundle
/api/vendor/bundle
!/api/log/.keep
!/api/tmp/.keep

# Reference screenshots (Phase 2 captures — kept local, not shipped to repo)
design/*.png

# Node / Playwright
node_modules/
test-results/
playwright-report/
.playwright/

# Demo video intermediates (large binaries; final mp4 shared separately)
demo/clips/
demo/audio/
demo/*.mp4

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/
